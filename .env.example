VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=

# Optional: only needed if you add Stripe.js / Payment Element in the browser.
# Live checkout in this app is created server-side (Supabase Edge Functions + STRIPE_SECRET_KEY).
VITE_STRIPE_PUBLISHABLE_KEY=

# Stripe Customer Portal URL — get from Stripe Dashboard → Billing → Customer portal → link
VITE_STRIPE_PORTAL_URL=

# Supabase Dashboard → Edge Functions → Secrets (not Vite):
# QUICKBOOKS_CLIENT_ID / QUICKBOOKS_CLIENT_SECRET — Intuit Development keys for sandbox; Production keys for live QBO.
# QUICKBOOKS_USE_SANDBOX=true — use sandbox-quickbooks.api.intuit.com in quickbooks-hotel-sync (set false for production API).
# QUICKBOOKS_REDIRECT_URI — optional; default is ${SITE_URL}/integrations/qb-callback. Must match Intuit Redirect URIs exactly.
